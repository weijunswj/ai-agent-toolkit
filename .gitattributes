# Auto detect text files and perform LF normalization
* text=auto

# Project _main/ folders preserve upstream source bytes for SOURCE-LOCK audits.
_projects/**/_main/** -text

# Exact source-locked helper copies preserve upstream source bytes too.
for_ai/templates/n8n/sync-helpers/validate-n8n-workflows.cjs -text whitespace=cr-at-eol
skills/n8n-workflow-sync/templates/sync-helpers/validate-n8n-workflows.cjs -text whitespace=cr-at-eol

# Design skill Markdown is validated as LF-only.
for_ai/skills/design/ui-ux-secure-frontend-design/**/*.md text eol=lf
skills/ui-ux-secure-frontend-design/**/*.md text eol=lf

# Generated pack manifests are deterministic LF JSON.
skills/**/packs/**/*.json text eol=lf

# Generated byte-for-byte design tool outputs must stay platform-stable.
for_ai/tools/design-system-generator/data/** -text whitespace=cr-at-eol
for_ai/tools/design-system-generator/scripts/core.py -text
for_ai/tools/design-system-generator/scripts/design_system.py -text
skills/ui-ux-secure-frontend-design/tools/design-system-generator/data/** -text whitespace=cr-at-eol
skills/ui-ux-secure-frontend-design/tools/design-system-generator/scripts/core.py -text
skills/ui-ux-secure-frontend-design/tools/design-system-generator/scripts/design_system.py -text
