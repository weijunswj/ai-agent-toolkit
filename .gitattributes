skills/n8n-workflow-helper-scripts/templates/helper-scripts/import-export-sync/*.ps1 -text whitespace=cr-at-eol

# Generated CI workflow templates are compared byte-for-byte by sync checks.
skills/context-preserving-ai-publisher/templates/ci/*.yml text eol=lf

# Generated byte-for-byte text copies must stay platform-stable across checkouts.
_projects/development/ai-coding-agent-rules/curated_output_for_ai/skills/ai-coding-agent-rules/**/*.md text eol=lf
skills/ai-coding-agent-rules/**/*.md text eol=lf
