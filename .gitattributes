# Auto detect text files and perform LF normalization
* text=auto

# Project _main/ folders preserve upstream source bytes for SOURCE-LOCK audits.
_projects/**/_main/** -text
_projects/n8n/workflow-toolkit/_main/README.md -text whitespace=cr-at-eol

# Exact source-locked helper copies preserve upstream source bytes too.
skills/n8n-workflow-helper-scripts/templates/helper-scripts/sanitizer/*.cmd -text whitespace=cr-at-eol
skills/n8n-workflow-helper-scripts/templates/helper-scripts/sanitizer/*.js -text whitespace=cr-at-eol
skills/n8n-workflow-helper-scripts/templates/helper-scripts/sanitizer/*.ps1 -text whitespace=cr-at-eol
skills/n8n-workflow-helper-scripts/templates/helper-scripts/import-export-sync/*.cmd -text whitespace=cr-at-eol
