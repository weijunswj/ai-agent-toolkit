{
  "id": "secure-cicd",
  "title": "Secure CI/CD",
  "description": "Security-first CI/CD installer guide, prompt, and status templates.",
  "status": "ready",
  "risk_level": "medium",
  "source_refs": [
    "guides/cicd/secure-cicd-installer.md",
    "templates/cicd/secure-cicd-prompt.md"
  ],
  "suitable_for": [
    "GitHub repositories",
    "AI coding agents"
  ],
  "installs": [
    "guides/cicd/secure-cicd-installer.md",
    "templates/cicd/secure-cicd-prompt.md",
    "templates/cicd/CURRENT_CICD_STATUS.template.md",
    "templates/cicd/safe-source-update-policy.md",
    "templates/github-actions/README.md"
  ],
  "writes_allowed": [
    "consumer repo docs and workflow template paths approved by the user"
  ],
  "writes_denied": [
    ".env*",
    ".n8n-local/**",
    ".tmp/**",
    "node_modules/**",
    "dist/**",
    "_dist/**",
    "*.pem",
    "*.key",
    "*.p12",
    "*.pfx",
    "*credential*",
    "*.zip",
    "*.tgz"
  ],
  "requires_approval": true,
  "run_commands": false,
  "notes": [
    "CI/CD templates must not auto-commit, push, merge, or deploy.",
    "Deployment stays disabled until approved in the consumer repo."
  ]
}
