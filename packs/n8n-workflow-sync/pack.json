{
  "id": "n8n-workflow-sync",
  "title": "n8n Workflow Sync",
  "description": "Credential-safe n8n workflow sync, sanitizer, and template hygiene materials.",
  "status": "ready",
  "risk_level": "high",
  "source_refs": [
    "weijunswj/ai-cicd-installer",
    "weijunswj/n8n-workflow-templates"
  ],
  "suitable_for": [
    "n8n workflow repositories",
    "AI coding agents"
  ],
  "installs": [
    "skills/automation/n8n-workflow-sync/",
    "guides/n8n/workflow-sync.md",
    "guides/n8n/credential-safety.md",
    "templates/n8n/README.md",
    "templates/n8n/sync-helpers/",
    "templates/n8n/sanitizer/",
    "templates/n8n/workflow-policy/"
  ],
  "writes_allowed": [
    "consumer repo template/helper paths approved by the user"
  ],
  "writes_denied": [
    ".env*",
    ".n8n-local/**",
    ".tmp/**",
    ".to-sanitise/**",
    ".sanitised/**",
    "node_modules/**",
    "dist/**",
    "_dist/**",
    "*.live-export.json",
    "*.live-import.json",
    "*.pem",
    "*.key",
    "*.p12",
    "*.pfx",
    "*credential*",
    "*.zip",
    "*.tgz"
  ],
  "requires_approval": true,
  "run_commands": false,
  "notes": [
    "Live n8n import/export is never run by this pack.",
    "Helper scripts are review-required templates, not trusted runtime code."
  ]
}
