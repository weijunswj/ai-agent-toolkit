{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/weijunswj/ai-agent-toolkit/schemas/external-system/history-discovery.v1.json",
  "title": "Last-Resort Browser-History Discovery",
  "type": "object",
  "additionalProperties": false,
  "required": ["reason", "browser", "profile", "domains", "startTime", "endTime", "unrelatedExposure", "stopCondition", "saferPaths", "ownerApproval"],
  "properties": {
    "reason": {"$ref": "#/$defs/statement"},
    "browser": {"$ref": "#/$defs/statement"},
    "profile": {"type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{0,127}$"},
    "domains": {"type": "array", "minItems": 1, "maxItems": 10, "uniqueItems": true, "items": {"type": "string", "pattern": "^(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\\.)+[a-zA-Z]{2,63}$"}},
    "startTime": {"type": "string", "format": "date-time"},
    "endTime": {"type": "string", "format": "date-time"},
    "unrelatedExposure": {"$ref": "#/$defs/list"},
    "stopCondition": {"$ref": "#/$defs/statement"},
    "saferPaths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["committed-requirements", "local-target-registry", "configured-interface-metadata", "approved-context-origins", "safe-public-provider-metadata-or-approved-tabs", "ask-owner-for-url"],
      "properties": {
        "committed-requirements": {"$ref": "#/$defs/failedAttempt"},
        "local-target-registry": {"$ref": "#/$defs/failedAttempt"},
        "configured-interface-metadata": {"$ref": "#/$defs/failedAttempt"},
        "approved-context-origins": {"$ref": "#/$defs/failedAttempt"},
        "safe-public-provider-metadata-or-approved-tabs": {"$ref": "#/$defs/failedAttempt"},
        "ask-owner-for-url": {"$ref": "#/$defs/failedAttempt"}
      }
    },
    "ownerApproval": {
      "type": "object", "additionalProperties": false,
      "required": ["ownerApproved", "source", "authorisationReference", "requestDigest"],
      "properties": {
        "ownerApproved": {"const": true}, "source": {"const": "owner"},
        "authorisationReference": {"$ref": "#/$defs/statement"},
        "requestDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{16,64}$"}
      }
    },
    "targetFound": {"type": "boolean"}
  },
  "$defs": {
    "statement": {"type": "string", "minLength": 1, "maxLength": 500},
    "list": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 300}},
    "failedAttempt": {
      "type": "object", "additionalProperties": false, "required": ["attempted", "failedReason"],
      "properties": {"attempted": {"const": true}, "failedReason": {"$ref": "#/$defs/statement"}}
    }
  }
}
