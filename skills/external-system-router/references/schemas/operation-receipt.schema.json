{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/weijunswj/ai-agent-toolkit/schemas/external-system/operation-receipt.v1.json",
  "title": "External System Operation Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "operationId", "operation", "provider", "adapter", "targetAlias", "accountOrOrganisation", "resource", "targetFingerprint", "environment", "riskTier", "operationSemanticsVersion", "operationSemanticsDigest", "mutationClass", "receiptClass", "selectedAuditReadOnly", "inventoryAuthorityId", "inventorySourceDigest", "authorisationReference", "authorisationEnvelopeDigest", "authorisationLifetimeKind", "selectedInterface", "capabilityDigest", "inventoryGeneration", "inventoryDigest", "selectedRouteDigest", "precondition", "preconditionEvidence", "mutationAttempted", "mutationPerformed", "postcondition", "postconditionEvidence", "rollbackAttempted", "rollbackPerformed", "rollbackEvidence", "stableCode", "safeEvidenceReferences", "supportedNextAction", "unchangedScope"],
  "properties": {
    "schemaVersion": {"const": "ai-agent-toolkit.operation-receipt.v1"},
    "operationId": {"type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]{0,127}$"},
    "operation": {"$ref": "#/$defs/name"},
    "provider": {"$ref": "#/$defs/name"},
    "adapter": {"$ref": "#/$defs/name"},
    "targetAlias": {"$ref": "#/$defs/name"},
    "accountOrOrganisation": {"$ref": "#/$defs/name"},
    "resource": {"$ref": "#/$defs/name"},
    "targetFingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{16,64}$"},
    "environment": {"$ref": "#/$defs/name"},
    "riskTier": {"type": "integer", "minimum": 0, "maximum": 3},
    "operationSemanticsVersion": {"const": "ai-agent-toolkit.operation-semantics.v1"},
    "operationSemanticsDigest": {"$ref": "#/$defs/digest"},
    "mutationClass": {"enum": ["read-only", "mutation"]},
    "receiptClass": {"enum": ["inspection", "mutation", "destructive"]},
    "selectedAuditReadOnly": {"type": "boolean"},
    "inventoryAuthorityId": {"$ref": "#/$defs/digest"},
    "inventorySourceDigest": {"$ref": "#/$defs/digest"},
    "authorisationReference": {"type": "string", "minLength": 1, "maxLength": 200},
    "authorisationEnvelopeDigest": {"$ref": "#/$defs/digest"},
    "authorisationLifetimeKind": {"enum": ["task", "time-bounded"]},
    "taskId": {"$ref": "#/$defs/name"},
    "sessionFingerprint": {"$ref": "#/$defs/digest"},
    "objectiveDigest": {"$ref": "#/$defs/digest"},
    "selectedInterface": {"$ref": "#/$defs/name"},
    "capabilityDigest": {"$ref": "#/$defs/digest"},
    "inventoryGeneration": {"$ref": "#/$defs/digest"},
    "inventoryDigest": {"$ref": "#/$defs/digest"},
    "hostAdapterPlanDigest": {"$ref": "#/$defs/digest"},
    "selectedRouteDigest": {"$ref": "#/$defs/digest"},
    "precondition": {"enum": ["passed", "failed", "not-applicable"]},
    "preconditionEvidence": {"$ref": "#/$defs/evidence"},
    "mutationAttempted": {"type": "boolean"},
    "mutationPerformed": {"type": "boolean"},
    "postcondition": {"enum": ["passed", "failed", "not-run", "not-applicable"]},
    "postconditionEvidence": {"$ref": "#/$defs/evidence"},
    "rollbackAttempted": {"type": "boolean"},
    "rollbackPerformed": {"type": "boolean"},
    "rollbackEvidence": {"$ref": "#/$defs/evidence"},
    "stableCode": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,127}$"},
    "safeEvidenceReferences": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^(digest|receipt|test|public-doc|github-check):[a-zA-Z0-9._/-]+$"}},
    "supportedNextAction": {"type": "string", "minLength": 1, "maxLength": 300},
    "unchangedScope": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 200}}
  },
  "allOf": [
    {
      "if": {"properties": {"authorisationLifetimeKind": {"const": "task"}}},
      "then": {"required": ["taskId", "sessionFingerprint", "objectiveDigest"]}
    },
    {
      "if": {"properties": {"authorisationLifetimeKind": {"const": "time-bounded"}}},
      "then": {
        "not": {
          "anyOf": [
            {"required": ["taskId"]},
            {"required": ["sessionFingerprint"]},
            {"required": ["objectiveDigest"]}
          ]
        }
      }
    }
  ],
  "$defs": {
    "name": {"type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{0,127}$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{16,64}$"},
    "evidence": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^(digest|receipt|test|public-doc|github-check):[a-zA-Z0-9._/-]+$"}}
  }
}
