{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/weijunswj/ai-agent-toolkit/schemas/external-system/capability-audit.v1.json",
  "title": "Operation-Specific Interface Capability Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "provider", "targetAlias", "environment", "operation", "interfaceId", "interfaceKind",
    "identity", "version", "availableOperations", "targetBinding", "inputSchemaDigest", "authScopeStatus",
    "redaction", "retryIdempotency", "preconditions", "postconditions", "rollback", "failureSemantics",
    "capabilityDigest", "assuranceScore", "readOnly", "auditedAt", "evidenceReferences"
  ],
  "properties": {
    "schemaVersion": {"const": "ai-agent-toolkit.capability-audit.v1"},
    "provider": {"type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$"},
    "targetAlias": {"$ref": "#/$defs/name"},
    "environment": {"$ref": "#/$defs/name"},
    "operation": {"$ref": "#/$defs/name"},
    "interfaceId": {"$ref": "#/$defs/name"},
    "interfaceKind": {"enum": ["api", "cli", "sdk", "mcp", "connector", "browser", "computer-use", "owner-action"]},
    "identity": {"type": "string", "minLength": 1, "maxLength": 200},
    "version": {"type": "string", "minLength": 1, "maxLength": 100},
    "availableOperations": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/name"}},
    "targetBinding": {"$ref": "#/$defs/name"},
    "inputSchemaDigest": {"$ref": "#/$defs/digest"},
    "authScopeStatus": {"type": "string", "minLength": 1, "maxLength": 300},
    "redaction": {"$ref": "#/$defs/evidence"},
    "retryIdempotency": {"type": "string", "minLength": 1, "maxLength": 300},
    "preconditions": {"$ref": "#/$defs/evidence"},
    "postconditions": {"$ref": "#/$defs/evidence"},
    "rollback": {"$ref": "#/$defs/evidence"},
    "failureSemantics": {"$ref": "#/$defs/evidence"},
    "capabilityDigest": {"$ref": "#/$defs/digest"},
    "assuranceScore": {"type": "integer", "minimum": 0, "maximum": 100},
    "readOnly": {"type": "boolean"},
    "auditedAt": {"type": "string", "format": "date-time"},
    "evidenceReferences": {"$ref": "#/$defs/evidence"}
  },
  "$defs": {
    "name": {"type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{0,127}$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{16,64}$"},
    "evidence": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 300}}
  }
}
