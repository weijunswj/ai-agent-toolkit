# Copy to /data/maintenance/daily-security-check.env on the VPS and set mode 600.
# The systemd installer loads that file with EnvironmentFile=-/data/maintenance/daily-security-check.env.
# Keep real tokens, chat IDs, and email addresses out of chat and out of git.

# Optional non-secret health checks.
# HEALTHCHECK_URLS=https://app.example.com/health
# HEALTHCHECK_HOSTS=app.example.com
# BACKUP_PATHS=/data/backups

# Optional Telegram daily notification.
# NOTIFY_TELEGRAM_BOT_TOKEN=replace-with-owner-created-telegram-bot-token
# NOTIFY_TELEGRAM_CHAT_ID=replace-with-owner-chat-id
# NOTIFY_TELEGRAM_THREAD_ID=replace-with-topic-id-if-needed

# Optional local email daily notification. Requires a working local mailer.
# NOTIFY_EMAIL_TO=owner@example.com
# NOTIFY_EMAIL_SUBJECT_PREFIX=[Hostinger Coolify]
