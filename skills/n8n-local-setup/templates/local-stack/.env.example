# [ STEP 1: Fill These Before First Launch ]
# These are local-only values. You are allowed to make up strong random values.
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-local-postgres-password

N8N_ENCRYPTION_KEY=replace-with-long-random-value
TZ=Asia/Singapore
GENERIC_TIMEZONE=Asia/Singapore

# [ STEP 2: Keep These Local Defaults For First Launch ]
# N8N_HOST: type exactly localhost for this guide.
# Do not put http:// here. Do not put your ngrok domain here.
N8N_HOST=localhost

# This is the browser port on your computer.
# If http://localhost:5678 is already used, change this to 5679.
N8N_LOCAL_PORT=5678

# Keep http here. ngrok provides the public https URL later.
N8N_PROTOCOL=http

# If you changed N8N_LOCAL_PORT to 5679, change this to http://localhost:5679/
WEBHOOK_URL=http://localhost:5678/
N8N_PROXY_HOPS=1

# Leave these runtime settings alone unless you know why.
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_RUNNERS_ENABLED=true

# [ STEP 3: Fill These Later Only After Local n8n Works ]
# Open the ngrok Docker setup page:
# https://dashboard.ngrok.com/get-started/setup/docker
# This is the ngrok dashboard page for Docker, not Docker Desktop.
# Get NGROK_AUTHTOKEN from section 1.
# Get NGROK_DOMAIN from the free domain shown near the bottom of section 1.
# NGROK_DOMAIN is hostname only, like your-name.ngrok.app.
# When ready for ngrok, replace WEBHOOK_URL above with https://<NGROK_DOMAIN>/
# Do not change N8N_HOST for ngrok in this guide.
NGROK_AUTHTOKEN=replace-with-ngrok-authtoken
NGROK_DOMAIN=your-name.ngrok.app
