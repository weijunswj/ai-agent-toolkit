# [ STEP 1: Fill These Before First Launch ]
# These are local-only values. You are allowed to make up strong random values.
# Keep POSTGRES_DB and POSTGRES_USER visible so separate local stacks can use separate names.
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-local-postgres-password

N8N_ENCRYPTION_KEY=replace-with-long-random-value
LOCAL_TIMEZONE=Asia/Singapore

# [ STEP 2: Local Browser Port ]
# This is the browser port on your computer.
# If http://localhost:5678 is already used, change this to 5679.
N8N_LOCAL_PORT=5678

# [ STEP 3: Fill These Later Only After Local n8n Works ]
# Get NGROK_AUTHTOKEN here:
# https://dashboard.ngrok.com/get-started/your-authtoken
# Get NGROK_DOMAIN from the free domain shown on that same ngrok authtoken/get-started page.
# NGROK_DOMAIN is hostname only, like your-name.ngrok.app.
# The launcher builds the public webhook URL from NGROK_DOMAIN when you start the tunnel.
# You still open the editor in your browser at http://localhost:5678 or your chosen N8N_LOCAL_PORT.
NGROK_AUTHTOKEN=replace-with-ngrok-authtoken
NGROK_DOMAIN=your-name.ngrok.app
