########################################################
# [ STEP 1: Fill These Before First Production Launch ] #
########################################################
# - These production values stay private.
# - You can make up strong random values for passwords and keys.
# - Do not commit .env, backups, tokens, real domains, or private notes.

############
# Postgres #
############

# Keeping POSTGRES_DB and POSTGRES_USER visible so separate stacks can use separate names.
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-production-postgres-password

#######
# n8n #
#######

# DO NOT CHANGE THIS VALUE AFTER STARTING PRODUCTION n8n FOR THE FIRST TIME.
# This key is needed to decrypt saved n8n credentials in the database.
# If you restore from a backup, use the N8N_ENCRYPTION_KEY that came with that backup.
N8N_ENCRYPTION_KEY=replace-with-production-32-plus-random-characters
LOCAL_TIMEZONE=Asia/Singapore

# Optional image pins for production reproducibility.
# - Use a tag (like docker.n8n.io/n8nio/n8n:2.22.5) or a pinned digest.
# - After changing an image value in .env, use Update to pull and apply it.
N8N_IMAGE=docker.n8n.io/n8nio/n8n:stable
POSTGRES_IMAGE=postgres:16-alpine
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest

# Used by the production launcher Back up action.
N8N_BACKUP_RETENTION_DAYS=30

############################################################
# [ STEP 2: Fill These After Cloudflare Tunnel Is Ready ]  #
############################################################
# - The stack builds n8n public editor and webhook URLs from N8N_PUBLIC_URL.
# - The Cloudflare public hostname service URL must point to http://n8n:5678.

# Hostname-only value. No https://, no path, no slash, no port.
N8N_PUBLIC_HOST=n8n.example.com

# Full public n8n URL. Must start with https:// and end with /.
N8N_PUBLIC_URL=https://n8n.example.com/

#####################
# Cloudflare Tunnel #
#####################

# Create a Cloudflare Tunnel, publish N8N_PUBLIC_HOST to this tunnel,
# then paste the tunnel token here.
CLOUDFLARED_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
