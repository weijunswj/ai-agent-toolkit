{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weijunswj.github.io/ai-agent-toolkit/security-gate/review-packet.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "base",
    "head",
    "scanned_head_digest",
    "profile",
    "risk_review_required",
    "changed_files",
    "changed_file_manifest",
    "sensitive_locations",
    "references",
    "scanner_summary",
    "invariant_evidence",
    "unresolved_findings",
    "coverage_gaps",
    "supported_outcomes"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "base": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "head": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "scanned_head_digest": {
      "type": "string",
      "pattern": "^git-sha1:[0-9a-f]{40}$"
    },
    "changed_file_manifest": {
      "type": "object",
      "required": [
        "total_count",
        "included_count",
        "omitted_count",
        "sha256"
      ],
      "properties": {
        "total_count": {
          "type": "integer",
          "minimum": 0
        },
        "included_count": {
          "type": "integer",
          "minimum": 0
        },
        "omitted_count": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "supported_outcomes": {
      "const": [
        "AI_SECURITY_PASS",
        "AI_SECURITY_FINDINGS",
        "AI_SECURITY_INCOMPLETE",
        "AI_SECURITY_INFRA_BLOCKED"
      ]
    }
  },
  "additionalProperties": false
}
