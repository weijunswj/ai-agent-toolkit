{
  "id": "n8n.local-setup",
  "category": "n8n",
  "name": "local-setup",
  "title": "Local n8n Setup",
  "module_path": "projects/n8n/local-setup",
  "main_path": "projects/n8n/local-setup/main",
  "exports_path": "projects/n8n/local-setup/exports",
  "outputs": [
    {
      "kind": "skill",
      "source": "exports/skills/n8n-local-setup.md",
      "output": "skills/automation/n8n-local-setup/SKILL.md"
    },
    {
      "kind": "mcp",
      "source": "exports/mcp/n8n-local-setup.md",
      "output": "mcp/projects/n8n-local-setup.md"
    },
    {
      "kind": "guide",
      "source": "exports/guides/local-setup.md",
      "output": "guides/n8n/local-setup.md"
    },
    {
      "kind": "agent-rule-template",
      "source": "exports/templates/agent-rules/partials",
      "output": "templates/agent-rules/AGENTS.md",
      "title": "AGENTS.md AI Coding Agent Rules",
      "audience": "Codex or OpenCode"
    },
    {
      "kind": "agent-rule-template",
      "source": "exports/templates/agent-rules/partials",
      "output": "templates/agent-rules/CLAUDE.md",
      "title": "CLAUDE.md AI Coding Agent Rules",
      "audience": "Claude Code"
    },
    {
      "kind": "agent-rule-template",
      "source": "exports/templates/agent-rules/partials",
      "output": "templates/agent-rules/GEMINI.md",
      "title": "GEMINI.md AI Coding Agent Rules",
      "audience": "Antigravity or Gemini CLI"
    },
    {
      "kind": "pack",
      "source": "exports/packs/codex-n8n-local/pack.json",
      "output": "packs/codex-n8n-local/pack.json",
      "notice": false
    }
  ],
  "writes": {
    "allowed": [
      "skills/automation/n8n-local-setup/SKILL.md",
      "mcp/projects/n8n-local-setup.md",
      "guides/n8n/local-setup.md",
      "templates/agent-rules/AGENTS.md",
      "templates/agent-rules/CLAUDE.md",
      "templates/agent-rules/GEMINI.md",
      "packs/codex-n8n-local/pack.json",
      "registry/projects.registry.json"
    ],
    "denied": [
      ".env*",
      ".n8n-local/**",
      ".tmp/**",
      "**/*credential*",
      "**/*.key",
      "**/*.pem",
      "**/*.live-export.json",
      "**/*.live-import.json",
      "node_modules/**",
      "dist/**",
      "_dist/**"
    ]
  },
  "requires_approval": true,
  "run_commands_by_default": false,
  "live_actions": "explicit_confirmation_only",
  "ci_live_actions": false
}
