{
  "id": "cicd.secure-installer",
  "category": "cicd",
  "name": "secure-installer",
  "title": "Secure CI/CD Installer",
  "module_path": "projects/cicd/secure-installer",
  "main_path": "projects/cicd/secure-installer/main",
  "exports_path": "projects/cicd/secure-installer/exports",
  "outputs": [
    {
      "kind": "skill",
      "source": "exports/skills/secure-cicd-installer.md",
      "output": "skills/cicd/secure-cicd-installer/SKILL.md"
    },
    {
      "kind": "mcp",
      "source": "exports/mcp/secure-cicd-installer.md",
      "output": "mcp/projects/secure-cicd-installer.md"
    },
    {
      "kind": "guide",
      "source": "exports/guides/secure-cicd-installer.md",
      "output": "guides/cicd/secure-cicd-installer.md"
    },
    {
      "kind": "template",
      "source": "exports/templates/cicd/README.md",
      "output": "templates/cicd/README.md"
    },
    {
      "kind": "pack",
      "source": "exports/packs/secure-cicd/pack.json",
      "output": "packs/secure-cicd/pack.json",
      "notice": false
    }
  ],
  "writes": {
    "allowed": [
      "skills/cicd/secure-cicd-installer/SKILL.md",
      "mcp/projects/secure-cicd-installer.md",
      "guides/cicd/secure-cicd-installer.md",
      "templates/cicd/README.md",
      "packs/secure-cicd/pack.json",
      "registry/projects.registry.json"
    ],
    "denied": [
      ".env*",
      ".n8n-local/**",
      ".tmp/**",
      "**/*credential*",
      "**/*.key",
      "**/*.pem",
      "node_modules/**",
      "dist/**",
      "_dist/**",
      "deployment-secrets/**"
    ]
  },
  "requires_approval": true,
  "run_commands_by_default": false,
  "live_actions": "explicit_confirmation_only",
  "ci_live_actions": false
}
