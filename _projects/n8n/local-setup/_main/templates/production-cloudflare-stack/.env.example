########################################################
# n8n Production Self-Hosting With Cloudflare Tunnel   #
########################################################
# Copy this file to .env in your private production stack folder.
# Fill .env privately. Do not commit .env, backups, tokens, or real domains.

############
# Postgres #
############
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-production-postgres-password

#######
# n8n #
#######
# DO NOT CHANGE THIS VALUE AFTER PRODUCTION CREDENTIALS EXIST.
# Generate once, store in a password manager, and include it in your private restore plan.
N8N_ENCRYPTION_KEY=replace-with-production-32-plus-random-characters

# Hostname-only value. No https://, no path, no trailing slash.
N8N_PUBLIC_HOST=n8n.example.com

# Public n8n URL. Must start with https:// and end with /.
N8N_PUBLIC_URL=https://n8n.example.com/
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.example.com/
N8N_EDITOR_BASE_URL=https://n8n.example.com/
N8N_PROXY_HOPS=1

# Use an IANA timezone name.
GENERIC_TIMEZONE=Etc/UTC

#####################
# Cloudflare Tunnel #
#####################
# Create a Cloudflare Tunnel, publish N8N_PUBLIC_HOST to this tunnel, and set
# the Cloudflare public hostname service URL to:
#   http://n8n:5678
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
CLOUDFLARED_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

#################
# Image Choices #
#################
N8N_IMAGE=docker.n8n.io/n8nio/n8n:stable
POSTGRES_IMAGE=postgres:16-alpine

###################
# Backup Settings #
###################
# Used by the production launcher Back up now action.
N8N_BACKUP_RETENTION_DAYS=30
