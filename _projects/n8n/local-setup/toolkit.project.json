{
  "id": "n8n.local-setup",
  "category": "n8n",
  "name": "local-setup",
  "title": "Local n8n Setup",
  "module_path": "_projects/n8n/local-setup",
  "main_path": "_projects/n8n/local-setup/_main",
  "outputs": [
    {
      "kind": "linked",
      "output": "for_ai/skills/automation/n8n-local-setup/SKILL.md",
      "notes": "Published skill maintained under for_ai. Review when _main/ changes."
    },
    {
      "kind": "linked",
      "output": "for_ai/mcp/projects/n8n-local-setup.md",
      "notes": "Published MCP doc maintained under for_ai. Review when _main/ changes."
    },
    {
      "kind": "linked",
      "output": "for_ai/playbooks/n8n/local-setup.md",
      "notes": "AI/operator playbook maintained under for_ai. Review when _main/ changes."
    },
    {
      "kind": "concat",
      "sources": [
        "_main/templates/partials/ai-coding-agent-execution.md",
        "_main/templates/partials/n8n-mcp-rules.md",
        "for_ai/templates/agent-rules/partials/skill-routing-rules.md"
      ],
      "output": "for_ai/templates/agent-rules/AGENTS.md",
      "title": "AGENTS.md AI Coding Agent Rules",
      "intro": "Use this generated template for Codex or OpenCode."
    },
    {
      "kind": "concat",
      "sources": [
        "_main/templates/partials/ai-coding-agent-execution.md",
        "_main/templates/partials/n8n-mcp-rules.md",
        "for_ai/templates/agent-rules/partials/skill-routing-rules.md"
      ],
      "output": "for_ai/templates/agent-rules/CLAUDE.md",
      "title": "CLAUDE.md AI Coding Agent Rules",
      "intro": "Use this generated template for Claude Code."
    },
    {
      "kind": "concat",
      "sources": [
        "_main/templates/partials/ai-coding-agent-execution.md",
        "_main/templates/partials/n8n-mcp-rules.md",
        "for_ai/templates/agent-rules/partials/skill-routing-rules.md"
      ],
      "output": "for_ai/templates/agent-rules/GEMINI.md",
      "title": "GEMINI.md AI Coding Agent Rules",
      "intro": "Use this generated template for Antigravity or Gemini CLI."
    },
    {
      "kind": "linked",
      "output": "for_ai/templates/agent-rules/partials/skill-routing-rules.md",
      "notes": "Toolkit-only partial maintained under for_ai and included by concat recipes."
    },
    {
      "kind": "copy",
      "source": "_main/templates/antigravity-mcp-config.md",
      "output": "for_ai/templates/mcp-configs/antigravity-mcp-config.md"
    },
    {
      "kind": "copy",
      "source": "_main/templates/claude-mcp-config.md",
      "output": "for_ai/templates/mcp-configs/claude-mcp-config.md"
    },
    {
      "kind": "copy",
      "source": "_main/templates/codex-mcp-config.md",
      "output": "for_ai/templates/mcp-configs/codex-mcp-config.md"
    },
    {
      "kind": "copy",
      "source": "_main/templates/opencode-mcp-config.md",
      "output": "for_ai/templates/mcp-configs/opencode-mcp-config.md"
    },
    {
      "kind": "linked",
      "output": "for_ai/templates/mcp-configs/README.md",
      "notes": "AI-facing index for published MCP config templates."
    },
    {
      "kind": "linked",
      "output": "for_ai/packs/codex-n8n-local/pack.json",
      "notes": "Published install pack maintained under for_ai."
    },
    {
      "kind": "linked",
      "output": "for_ai/packs/claude-code-n8n-local/pack.json",
      "notes": "Published install pack maintained under for_ai."
    }
  ],
  "writes": {
    "allowed": [
      "for_ai/skills/automation/n8n-local-setup/SKILL.md",
      "for_ai/mcp/projects/n8n-local-setup.md",
      "for_ai/playbooks/n8n/local-setup.md",
      "for_ai/templates/agent-rules/AGENTS.md",
      "for_ai/templates/agent-rules/CLAUDE.md",
      "for_ai/templates/agent-rules/GEMINI.md",
      "for_ai/templates/agent-rules/partials/skill-routing-rules.md",
      "for_ai/templates/mcp-configs/antigravity-mcp-config.md",
      "for_ai/templates/mcp-configs/claude-mcp-config.md",
      "for_ai/templates/mcp-configs/codex-mcp-config.md",
      "for_ai/templates/mcp-configs/opencode-mcp-config.md",
      "for_ai/templates/mcp-configs/README.md",
      "for_ai/packs/codex-n8n-local/pack.json",
      "for_ai/packs/claude-code-n8n-local/pack.json",
      "for_ai/registry/projects.registry.json"
    ],
    "denied": [
      ".env*",
      ".n8n-local/**",
      ".tmp/**",
      "**/*credential*",
      "**/*.key",
      "**/*.pem",
      "**/*.live-export.json",
      "**/*.live-import.json",
      "node_modules/**",
      "dist/**",
      "_dist/**"
    ]
  },
  "requires_approval": true,
  "run_commands_by_default": false,
  "live_actions": "explicit_confirmation_only",
  "ci_live_actions": false
}
