{
  "id": "n8n.workflow-templates",
  "category": "n8n",
  "name": "workflow-templates",
  "title": "n8n Workflow Templates",
  "module_path": "_projects/n8n/workflow-templates",
  "main_path": "_projects/n8n/workflow-templates/_main",
  "outputs": [
    {
      "kind": "linked",
      "output": "skills/automation/n8n-workflow-sync/SKILL.md",
      "notes": "Published skill maintained at root. Review when _main/ changes."
    },
    {
      "kind": "linked",
      "output": "mcp/projects/n8n-workflow-templates.md",
      "notes": "Published MCP doc maintained at root. Review when _main/ changes."
    },
    {
      "kind": "linked",
      "output": "guides/n8n/workflow-sync.md",
      "notes": "Canonical root guide maintained at root. Review when _main/ changes."
    },
    {
      "kind": "linked",
      "output": "templates/n8n/sanitizer/README.md",
      "notes": "Root sanitizer documentation maintained at root."
    },
    {
      "kind": "linked",
      "output": "templates/n8n/sanitizer/- sanitise-n8n-template.cmd",
      "notes": "Root sanitizer wrapper is toolkit-adapted and source-locked."
    },
    {
      "kind": "linked",
      "output": "templates/n8n/sanitizer/prepare-n8n-template.js",
      "notes": "Root sanitizer script is toolkit-adapted and source-locked."
    },
    {
      "kind": "linked",
      "output": "templates/n8n/sanitizer/sanitise-n8n-template.ps1",
      "notes": "Root sanitizer wrapper is toolkit-adapted and source-locked."
    },
    {
      "kind": "linked",
      "output": "templates/n8n/workflow-policy/README.md",
      "notes": "Root workflow policy maintained at root."
    },
    {
      "kind": "linked",
      "output": "packs/n8n-workflow-sync/pack.json",
      "notes": "Published pack maintained at root."
    }
  ],
  "writes": {
    "allowed": [
      "skills/automation/n8n-workflow-sync/SKILL.md",
      "mcp/projects/n8n-workflow-templates.md",
      "guides/n8n/workflow-sync.md",
      "templates/n8n/sanitizer/README.md",
      "templates/n8n/sanitizer/- sanitise-n8n-template.cmd",
      "templates/n8n/sanitizer/prepare-n8n-template.js",
      "templates/n8n/sanitizer/sanitise-n8n-template.ps1",
      "templates/n8n/workflow-policy/README.md",
      "packs/n8n-workflow-sync/pack.json",
      "registry/projects.registry.json"
    ],
    "denied": [
      ".env*",
      ".n8n-local/**",
      ".tmp/**",
      "**/*credential*",
      "**/*.key",
      "**/*.pem",
      "**/*.live-export.json",
      "**/*.live-import.json",
      "node_modules/**",
      "dist/**",
      "_dist/**"
    ]
  },
  "requires_approval": true,
  "run_commands_by_default": false,
  "live_actions": "explicit_confirmation_only",
  "ci_live_actions": false
}
