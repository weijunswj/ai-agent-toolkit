    {
      "kind": "linked",
      "output": "mcp/projects/ui-ux-pro-max.md",
      "notes": "Published MCP doc maintained at root. Review when _main/ changes."
    },
    {
      "kind": "linked",
      "output": "guides/design/ui-ux-pro-max.md",
      "notes": "Canonical root guide maintained at root. Review when _main/ changes."
    },
    {
      "kind": "linked",
      "output": "tools/design-system-generator/README.md",
      "notes": "Root tool README maintained at root with toolkit safety context."
    },
    {
      "kind": "linked",
      "output": "tools/design-system-generator/LICENSE-THIRD-PARTY-NOTES.md",
      "notes": "Root third-party attribution maintained at root."
    },
    {
      "kind": "copy",
      "source": "_main/src/ui-ux-pro-max/scripts/core.py",
      "output": "tools/design-system-generator/scripts/core.py",
