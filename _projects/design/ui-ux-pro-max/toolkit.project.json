    {
      "kind": "copy",
      "source": "_main/src/ui-ux-pro-max/scripts/design_system.py",
      "output": "tools/design-system-generator/scripts/design_system.py",
      "notice": false
    },
    {
      "kind": "copy",
      "source": "_main/src/ui-ux-pro-max/data",
      "output": "tools/design-system-generator/data",
      "notice": false
    },
    {
      "kind": "linked",
      "output": "packs/design-system-generator/pack.json",
      "notes": "Published pack maintained at root."
    }
  ],
  "writes": {
    "allowed": [
      "skills/design/ui-ux-secure-frontend-design/SKILL.md",
      "mcp/projects/ui-ux-pro-max.md",
      "guides/design/ui-ux-pro-max.md",
