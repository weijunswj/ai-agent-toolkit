      ".tmp/**",
      "**/*credential*",
      "**/*.key",
      "**/*.pem",
      "node_modules/**",
      "dist/**",
      "_dist/**",
      "arbitrary-output-paths/**",
      "user-home/**",
      "system-paths/**"
