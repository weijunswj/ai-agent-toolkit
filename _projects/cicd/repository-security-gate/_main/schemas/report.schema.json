{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weijunswj.github.io/ai-agent-toolkit/security-gate/report.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "state",
    "repository",
    "mode",
    "base",
    "head",
    "scanned_head_digest",
    "artifact_digest",
    "profile",
    "versions",
    "coverage",
    "findings",
    "finding_duplicates",
    "suppressed_findings",
    "unverified_areas",
    "infrastructure_failures",
    "next_action"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "state": {
      "enum": [
        "SECURITY_PASS",
        "SECURITY_FINDINGS",
        "SECURITY_GATE_UNVERIFIED",
        "SECURITY_GATE_INFRA_BLOCKED",
        "SECURITY_PROFILE_EXEMPT"
      ]
    },
    "mode": {
      "enum": [
        "pr",
        "full",
        "scheduled",
        "release"
      ]
    },
    "scanned_head_digest": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^git-sha1:[0-9a-f]{40}$"
    },
    "profile": {
      "enum": [
        "SECURITY_PROFILE_EXEMPT",
        "SECURITY_PROFILE_LIGHTWEIGHT_CI",
        "SECURITY_PROFILE_TOOLING_LIBRARY",
        "SECURITY_PROFILE_WEB_API",
        "SECURITY_PROFILE_WORKFLOW_INTEGRATION"
      ]
    },
    "findings": {
      "type": "array"
    },
    "finding_duplicates": {
      "type": "array"
    },
    "suppressed_findings": {
      "type": "array"
    },
    "unverified_areas": {
      "type": "array"
    },
    "infrastructure_failures": {
      "type": "array"
    }
  },
  "additionalProperties": false
}
