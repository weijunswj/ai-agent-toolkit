{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weijunswj.github.io/ai-agent-toolkit/security-gate/consumer-invariants.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "profile",
    "tests"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "profile": {
      "enum": [
        "SECURITY_PROFILE_WEB_API",
        "SECURITY_PROFILE_WORKFLOW_INTEGRATION"
      ]
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": [
          "id",
          "runner",
          "path",
          "timeout_seconds"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]{1,80}$"
          },
          "runner": {
            "enum": [
              "node",
              "python",
              "powershell"
            ]
          },
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*\\.\\.)(?!.*[*?]).+$"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 120
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
