{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/weijunswj/ai-agent-toolkit/schemas/external-system/n8n-capability-ledger.v1.json",
  "title": "Fail-Closed n8n Task Capability Ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "taskId", "sessionFingerprint", "repositoryFingerprint", "objectiveDigest", "detection",
    "operation", "facets", "sourceContract", "requiredCapabilities", "invocationEvidence", "status", "createdAt", "updatedAt"
  ],
  "properties": {
    "schemaVersion": {"const": "ai-agent-toolkit.n8n-capability-ledger.v1"},
    "taskId": {"type": "string", "pattern": "^n8n-[0-9a-f]{24}$"},
    "sessionFingerprint": {"$ref": "#/$defs/digest"},
    "repositoryFingerprint": {"$ref": "#/$defs/digest"},
    "objectiveDigest": {"$ref": "#/$defs/digest"},
    "detection": {"type": "object"},
    "operation": {"type": ["string", "null"]},
    "facets": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "sourceContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageId", "pluginNamespace", "packageVersion", "sourceRepository", "sourceCommit", "compatibilityBaselineCommit", "supportedSourceCommits", "claudePluginManifestBlob", "codexPluginManifestBlob", "entryPoint", "compatibilityOwner", "contentCompatibility", "windowsHookRepairStatus"],
      "properties": {
        "packageId": {"const": "n8n-skills@n8n-io"},
        "pluginNamespace": {"const": "n8n-skills"},
        "packageVersion": {"const": "1.0.2"},
        "sourceRepository": {"const": "https://github.com/n8n-io/skills"},
        "sourceCommit": {"const": "eb18fc3ab3e2820c748c2d84386fb5496efc1516"},
        "compatibilityBaselineCommit": {"const": "2c26822deb522ea2862d864b0c808b767a13aa9a"},
        "supportedSourceCommits": {"const": ["2c26822deb522ea2862d864b0c808b767a13aa9a", "eb18fc3ab3e2820c748c2d84386fb5496efc1516"]},
        "claudePluginManifestBlob": {"const": "f8075e42c536cce8c8495e2a1a6310273e186119"},
        "codexPluginManifestBlob": {"const": "57dfb8d5354c8cf92fbe4035519521c523793a72"},
        "entryPoint": {"const": "using-n8n-skills-official"},
        "compatibilityOwner": {"const": "#244"},
        "contentCompatibility": {"const": "1.0.2-skill-blobs-unchanged-from-244-baseline"},
        "windowsHookRepairStatus": {"const": "remediation-required-and-owned-by-244"}
      }
    },
    "requiredCapabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["capabilityId", "kind", "name", "status", "evidence"],
        "properties": {
          "capabilityId": {"type": "string", "minLength": 1, "maxLength": 200},
          "kind": {"enum": ["classification", "official-skill", "toolkit-helper", "live-route", "external-route"]},
          "name": {"type": "string", "minLength": 1, "maxLength": 160},
          "ownerIssue": {"type": "string", "pattern": "^#[0-9]+$"},
          "status": {"enum": ["pending", "verified", "blocked"]},
          "evidence": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 240}},
          "blocker": {"type": "string", "minLength": 1, "maxLength": 500}
        },
        "additionalProperties": false
      }
    },
    "invocationEvidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["invocationId", "skillName", "result", "accepted", "sourceStatus", "packageId", "packageVersion", "sourceRepository", "sourceCommit", "compatibilityBaselineCommit", "compatibilityReference", "contentCompatibility", "manifestBlob", "skillBlob", "sourceFingerprint", "normalization", "host", "event", "invokedAt"],
        "additionalProperties": false,
        "properties": {
          "invocationId": {"type": "string", "minLength": 1, "maxLength": 160},
          "skillName": {"type": "string", "minLength": 1, "maxLength": 160},
          "result": {"enum": ["success", "failed"]},
          "accepted": {"type": "boolean"},
          "sourceStatus": {"type": "string"},
          "packageId": {"type": "string"},
          "packageVersion": {"type": "string"},
          "sourceRepository": {"type": "string"},
          "sourceCommit": {"type": "string"},
          "compatibilityBaselineCommit": {"type": "string"},
          "compatibilityReference": {"type": "string"},
          "contentCompatibility": {"type": "string"},
          "manifestBlob": {"type": "string"},
          "skillBlob": {"type": "string"},
          "sourceFingerprint": {"type": "string"},
          "normalization": {"type": "string"},
          "host": {"type": "string"},
          "event": {"type": "string"},
          "invokedAt": {"type": "string", "format": "date-time"}
        }
      }
    },
    "status": {"enum": ["pending", "blocked", "complete"]},
    "createdAt": {"type": "string", "format": "date-time"},
    "updatedAt": {"type": "string", "format": "date-time"}
  },
  "$defs": {"digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}}
}
