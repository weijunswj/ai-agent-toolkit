{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/weijunswj/ai-agent-toolkit/schemas/external-system/consumer-requirements.v1.json",
  "title": "External System Consumer Requirements",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "providers"],
  "properties": {
    "schemaVersion": {"const": "ai-agent-toolkit.external-consumer-requirements.v1"},
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["provider", "requiredCapabilities", "environmentAliases", "verification", "rollbackExpectations", "forbiddenOperations", "browserFallbackAllowed"],
        "properties": {
          "provider": {"type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$"},
          "requiredCapabilities": {"$ref": "#/$defs/names"},
          "environmentAliases": {"$ref": "#/$defs/names"},
          "publicOrigins": {"type": "array", "uniqueItems": true, "items": {"type": "string", "format": "uri", "pattern": "^https://"}},
          "contextualRiskOverrides": {
            "type": "object",
            "propertyNames": {"$ref": "#/$defs/name"},
            "additionalProperties": {"type": "integer", "minimum": 0, "maximum": 3}
          },
          "verification": {"$ref": "#/$defs/statements"},
          "rollbackExpectations": {"$ref": "#/$defs/statements"},
          "forbiddenOperations": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/name"}},
          "browserFallbackAllowed": {"type": "boolean"}
        }
      }
    }
  },
  "$defs": {
    "name": {"type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{0,127}$"},
    "names": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/name"}},
    "statements": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 300}}
  }
}
