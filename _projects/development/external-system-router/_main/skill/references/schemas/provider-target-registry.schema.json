{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/weijunswj/ai-agent-toolkit/schemas/external-system/provider-target-registry.v1.json",
  "title": "User-Local Provider Target Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "targets"],
  "properties": {
    "schemaVersion": {"const": "ai-agent-toolkit.provider-target-registry.v1"},
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["provider", "targetAlias", "accountOrOrganisation", "environment", "sanitizedFingerprint", "credentialReferences", "installedInterfaces", "capabilityDigests", "routeSelections", "lastAuditState", "receiptReferences"],
        "properties": {
          "provider": {"type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$"},
          "targetAlias": {"$ref": "#/$defs/name"},
          "accountOrOrganisation": {"$ref": "#/$defs/name"},
          "environment": {"$ref": "#/$defs/name"},
          "sanitizedFingerprint": {"$ref": "#/$defs/digest"},
          "privateOriginReference": {"type": "string", "pattern": "^(credential-store|local-registry|os-keychain)://[a-zA-Z0-9._/-]+$"},
          "resourceReferences": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/name"}},
          "credentialReferences": {
            "type": "array", "minItems": 1, "uniqueItems": true,
            "items": {"type": "string", "pattern": "^(credential-store|os-keychain|password-manager|secret-broker|session-injection)://[a-zA-Z0-9._/-]+$"}
          },
          "multipleCredentialJustification": {"type": "string", "minLength": 1, "maxLength": 500},
          "installedInterfaces": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/name"}},
          "capabilityDigests": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/digest"}},
          "routeSelections": {"type": "object", "propertyNames": {"$ref": "#/$defs/name"}, "additionalProperties": {"$ref": "#/$defs/name"}},
          "lastAuditState": {"$ref": "#/$defs/name"},
          "receiptReferences": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/name"}}
        },
        "allOf": [
          {
            "if": {"properties": {"credentialReferences": {"minItems": 2}}},
            "then": {"required": ["multipleCredentialJustification"]}
          }
        ]
      }
    }
  },
  "$defs": {
    "name": {"type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{0,127}$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{16,64}$"}
  }
}
