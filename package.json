    "build:agent-rules": "pwsh -NoProfile -File scripts/build-agent-rule-templates.ps1",
    "package:skills:check": "node scripts/package-skills.cjs --check",
    "package:packs:check": "node scripts/package-packs.cjs --check",
    "safe-source-update": "node scripts/safe-source-update.cjs"
