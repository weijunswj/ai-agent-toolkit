{
  "name": "ai-agent-toolkit",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable AI-agent skills, guides, templates, packs, registries, and MCP design docs.",
  "type": "commonjs",
  "scripts": {
    "validate": "node scripts/validate-toolkit.cjs",
    "test": "node --test tests/*.test.cjs",
